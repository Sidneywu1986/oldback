.header {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  padding: 40rpx;
  text-align: center;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
}

.activity-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.activity-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.activity-type text:first-child {
  font-size: 32rpx;
}

.type-label {
  font-size: 24rpx;
  color: #6B7280;
  background: #F3F4F6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.activity-status {
  background: #10B981;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.activity-body {
  margin-bottom: 16rpx;
}

.activity-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
}

.activity-desc {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.activity-rules {
  background: #FEF3C7;
  border-radius: 12rpx;
  padding: 16rpx;
}

.rule-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.rule-label {
  font-size: 26rpx;
  color: #9CA3AF;
}

.rule-value {
  font-size: 28rpx;
  color: #D97706;
  font-weight: 600;
}

.rule-value.highlight {
  font-size: 36rpx;
  color: #DC2626;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #E5E7EB;
}

.activity-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.participate-btn {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
}

.participate-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.empty-state {
  text-align: center;
  padding: 80rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #9CA3AF;
}