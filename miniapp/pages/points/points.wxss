.points-card {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  text-align: center;
  color: #FFFFFF;
}

.points-header {
  margin-bottom: 16rpx;
}

.points-title {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.points-subtitle {
  font-size: 24rpx;
  opacity: 0.7;
}

.points-amount {
  margin-bottom: 24rpx;
}

.amount-number {
  font-size: 72rpx;
  font-weight: 700;
}

.amount-unit {
  font-size: 28rpx;
  opacity: 0.9;
  margin-left: 8rpx;
}

.points-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
}

.stats-list {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.record-info {
  flex: 1;
}

.record-type {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  display: block;
}

.record-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rule-icon {
  font-size: 28rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #374151;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}