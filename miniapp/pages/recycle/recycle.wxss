.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(50% - 8rpx);
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 2rpx solid transparent;
}

.category-item.active {
  background: #EFF6FF;
  border-color: #2563EB;
}

.category-icon {
  font-size: 48rpx;
}

.category-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}

.category-ratio {
  font-size: 22rpx;
  color: #2563EB;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #374151;
}

.qty-btn:active {
  background: #E5E7EB;
}

.qty-input {
  width: 120rpx;
  height: 64rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}

.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
}

.upload-btn {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  background: #F9FAFB;
  border-radius: 12rpx;
  border: 2rpx dashed #D1D5DB;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-icon {
  font-size: 40rpx;
  color: #9CA3AF;
}

.upload-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.summary-item:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #374151;
}

.summary-value {
  font-size: 32rpx;
}

.submit-area {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn[disabled] {
  background: #D1D5DB;
}

.submit-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 16rpx;
}

.card-tip {
  font-size: 22rpx;
  color: #9CA3AF;
}