.status-card {
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #2563EB;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6B7280;
}

.info-value {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.grid-image {
  width: calc(33.33% - 8rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
}

.amount-list {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.amount-item {
  text-align: center;
}

.amount-label {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.amount-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #2563EB;
}

.action-area {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.action-area button {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}