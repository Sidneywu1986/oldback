.tabs {
  display: flex;
  background: #FFFFFF;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #6B7280;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active {
  color: #2563EB;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #2563EB;
  border-radius: 2rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 26rpx;
  color: #9CA3AF;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-body {
  margin-bottom: 16rpx;
}

.parts-info {
  margin-bottom: 12rpx;
}

.parts-name {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
  display: block;
}

.parts-spec {
  font-size: 24rpx;
  color: #9CA3AF;
}

.parts-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #6B7280;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F3F4F6;
}

.order-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.order-amount {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.amount-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.amount-value {
  font-size: 32rpx;
  color: #2563EB;
  font-weight: 600;
}

.points-value {
  font-size: 24rpx;
  color: #F59E0B;
}

.order-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.order-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.loading-state {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #9CA3AF;
}