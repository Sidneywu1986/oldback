<view class="container">
  <view class="location-bar">
    <view class="location-icon">📍</view>
    <view class="location-info">
      <text class="location-label">当前位置</text>
      <text class="location-value">{{currentAddress}}</text>
    </view>
    <view class="refresh-btn" bindtap="refreshLocation">🔄</view>
  </view>

  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{nearbyOrders.length}}</text>
      <text class="stat-label">附近订单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{grabCount}}</text>
      <text class="stat-label">今日抢单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{successRate}}%</text>
      <text class="stat-label">成功率</text>
    </view>
  </view>

  <view class="map-card">
    <map
      id="nearbyMap"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      show-location
      show-compass
      show-scale
      enable-zoom
      enable-scroll
      style="width: 100%; height: 400rpx;"
      bindmarkertap="onMarkerTap"
      bindregionchange="onRegionChange"
    ></map>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">🔥 可抢订单</text>
      <text class="card-tip">共 {{nearbyOrders.length}} 个订单</text>
    </view>

    <view class="order-list">
      <view class="order-item" wx:for="{{nearbyOrders}}" wx:key="id" bindtap="showOrderDetail" data-order="{{item}}">
        <view class="order-header">
          <text class="order-no">订单号：{{item.order_no}}</text>
          <view class="order-distance">
            <text class="distance-icon">📍</text>
            <text class="distance-value">{{item.distance}}km</text>
          </view>
        </view>
        
        <view class="order-body">
          <view class="parts-info">
            <text class="parts-name">{{item.parts_name}}</text>
            <text class="parts-category">{{item.category_name}}</text>
          </view>
          <view class="parts-meta">
            <text class="meta-item">数量：{{item.quantity}}件</text>
            <text class="meta-item" wx:if="{{item.weight}}">重量：{{item.weight}}kg</text>
          </view>
        </view>

        <view class="order-footer">
          <view class="order-price">
            <text class="price-label">预估金额</text>
            <text class="price-value">¥{{item.amount}}</text>
          </view>
          <button class="grab-btn" bindtap="grabOrder" data-id="{{item.id}}" data-order_no="{{item.order_no}}">
            抢单
          </button>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{nearbyOrders.length === 0 && !loading}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无附近订单</text>
      <text class="empty-tip">请确保已开启定位权限</text>
    </view>
  </view>
</view>