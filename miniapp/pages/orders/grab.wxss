.location-bar {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.location-icon {
  font-size: 40rpx;
}

.location-info {
  flex: 1;
}

.location-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.location-value {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.refresh-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.stats-bar {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2563EB;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E7EB;
}

.map-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.card-tip {
  font-size: 24rpx;
  color: #9CA3AF;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 26rpx;
  color: #9CA3AF;
}

.order-distance {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FEF3C7;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.distance-icon {
  font-size: 24rpx;
}

.distance-value {
  font-size: 24rpx;
  color: #D97706;
  font-weight: 500;
}

.order-body {
  margin-bottom: 16rpx;
}

.parts-info {
  margin-bottom: 12rpx;
}

.parts-name {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
  display: block;
}

.parts-category {
  font-size: 24rpx;
  color: #2563EB;
  background: #EFF6FF;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.parts-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #6B7280;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #E5E7EB;
}

.order-price {
  display: flex;
  flex-direction: column;
}

.price-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.price-value {
  font-size: 36rpx;
  color: #10B981;
  font-weight: 700;
}

.grab-btn {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #9CA3AF;
}