<view class="container">
  <view class="status-card" style="background: {{statusBgColor}}">
    <text class="status-text">{{statusText}}</text>
    <text class="status-desc">{{statusDesc}}</text>
  </view>

  <view class="card">
    <view class="section-title">📋 订单信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">订单编号</text>
        <text class="info-value">{{order.order_no}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">提交时间</text>
        <text class="info-value">{{order.create_time}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">配件分类</text>
        <text class="info-value">{{order.category_name}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">📦 配件信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">配件名称</text>
        <text class="info-value">{{order.parts_name}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">配件编号</text>
        <text class="info-value">{{order.parts_code || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">数量</text>
        <text class="info-value">{{order.quantity}}件</text>
      </view>
      <view class="info-item" wx:if="{{order.weight}}">
        <text class="info-label">重量</text>
        <text class="info-value">{{order.weight}}kg</text>
      </view>
      <view class="info-item" wx:if="{{order.remark}}">
        <text class="info-label">备注</text>
        <text class="info-value">{{order.remark}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{order.images}}">
    <view class="section-title">📷 配件照片</view>
    <view class="images-grid">
      <image wx:for="{{images}}" wx:key="index" src="{{item}}" mode="aspectFill" class="grid-image" bindtap="previewImage" data-index="{{index}}" />
    </view>
  </view>

  <view class="card" wx:if="{{order.audit_time}}">
    <view class="section-title">✅ 审核信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">审核时间</text>
        <text class="info-value">{{order.audit_time}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">审核人员</text>
        <text class="info-value">{{order.audit_user_name || '系统'}}</text>
      </view>
      <view class="info-item" wx:if="{{order.audit_remark}}">
        <text class="info-label">审核意见</text>
        <text class="info-value">{{order.audit_remark}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">💰 金额信息</view>
    <view class="amount-list">
      <view class="amount-item">
        <text class="amount-label">预计金额</text>
        <text class="amount-value">¥{{order.amount}}</text>
      </view>
      <view class="amount-item">
        <text class="amount-label">预计积分</text>
        <text class="amount-value text-warning">{{order.points}}</text>
      </view>
    </view>
  </view>

  <view class="action-area">
    <button class="btn-secondary" bindtap="goBack">返回列表</button>
    <button class="btn-primary" bindtap="contactAdmin" wx:if="{{order.status === 0}}">联系客服</button>
  </view>
</view>