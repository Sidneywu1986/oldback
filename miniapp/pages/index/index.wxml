<view class="container">
  <view class="banner">
    <swiper indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true">
      <swiper-item>
        <view class="banner-item">
          <text class="banner-text">回收配件</text>
          <text class="banner-desc">让每一个配件都有价值</text>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-item banner-item-2">
          <text class="banner-text">积分兑换</text>
          <text class="banner-desc">积分当钱花</text>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-item banner-item-3">
          <text class="banner-text">专业服务</text>
          <text class="banner-desc">品质保证</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="quick-actions">
    <view class="action-item" bindtap="goToRecycle">
      <view class="action-icon action-icon-recycle">
        <text class="icon-text">📦</text>
      </view>
      <text class="action-text">我要回收</text>
    </view>
    <view class="action-item" bindtap="goToGrab">
      <view class="action-icon action-icon-grab">
        <text class="icon-text">�</text>
      </view>
      <text class="action-text">抢单大厅</text>
    </view>
    <view class="action-item" bindtap="goToPoints">
      <view class="action-icon action-icon-points">
        <text class="icon-text">⭐</text>
      </view>
      <text class="action-text">我的积分</text>
    </view>
    <view class="action-item" bindtap="goToProfile">
      <view class="action-icon action-icon-profile">
        <text class="icon-text">👤</text>
      </view>
      <text class="action-text">个人中心</text>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">📊 今日数据</text>
    </view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{todayStats.recycleCount}}</text>
        <text class="stat-label">今日回收</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{todayStats.pointsEarned}}</text>
        <text class="stat-label">今日积分</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{todayStats.orderAmount}}</text>
        <text class="stat-label">今日金额</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">🔥 热门分类</text>
      <text class="card-more" bindtap="goToCategory">查看更多 →</text>
    </view>
    <view class="category-list">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">
        <view class="category-icon">{{item.icon}}</view>
        <text class="category-name">{{item.name}}</text>
        <text class="category-ratio">{{item.pointsRatio}}倍积分</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">📝 最新订单</text>
      <text class="card-more" bindtap="goToOrders">查看全部 →</text>
    </view>
    <view class="order-list">
      <view class="order-item" wx:for="{{recentOrders}}" wx:key="id" bindtap="goToOrderDetail" data-id="{{item.id}}">
        <view class="order-info">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-status" style="color: {{getStatusColor(item.status)}}">{{getStatusText(item.status)}}</text>
        </view>
        <view class="order-content">
          <text class="order-parts">{{item.partsName}}</text>
          <text class="order-amount">¥{{item.amount}}</text>
        </view>
        <text class="order-time">{{item.createTime}}</text>
      </view>
    </view>
  </view>
</view>