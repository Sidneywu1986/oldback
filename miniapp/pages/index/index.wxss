.banner {
  margin-bottom: 24rpx;
}

.banner-item {
  height: 280rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #FFFFFF;
}

.banner-item-2 {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.banner-item-3 {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
}

.banner-text {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.quick-actions {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon-recycle {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
}

.action-icon-grab {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
}

.action-icon-points {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
}

.action-icon-profile {
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
}

.icon-text {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: #374151;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.card-more {
  font-size: 24rpx;
  color: #2563EB;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2563EB;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(25% - 12rpx);
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.category-icon {
  font-size: 36rpx;
}

.category-name {
  font-size: 24rpx;
  color: #374151;
}

.category-ratio {
  font-size: 20rpx;
  color: #2563EB;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-item {
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 24rpx;
  color: #9CA3AF;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.order-parts {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
}

.order-amount {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}

.order-time {
  font-size: 22rpx;
  color: #9CA3AF;
}