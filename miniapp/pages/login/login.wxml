<view class="login-container">
  <view class="logo-section">
    <view class="logo-icon">♻️</view>
    <text class="logo-title">飞玖回收</text>
    <text class="logo-subtitle">专业的汽车配件回收平台</text>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" type="number" value="{{formData.phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" placeholder="请输入密码" type="password" value="{{formData.password}}" bindinput="onPasswordInput" />
    </view>

    <view class="form-item">
      <view class="checkbox-wrap" bindtap="toggleRemember">
        <view class="checkbox {{rememberMe ? 'checked' : ''}}">
          <text wx:if="{{rememberMe}}" class="check-icon">✓</text>
        </view>
        <text class="checkbox-text">记住密码</text>
      </view>
      <text class="forgot-password" bindtap="goToForgot">忘记密码？</text>
    </view>

    <button class="btn-primary login-btn" bindtap="handleLogin" disabled="{{!canSubmit}}">
      登录
    </button>
  </view>

  <view class="tips-section">
    <text class="tip-text">测试账号：13800138001 / 123456</text>
    <text class="tip-text">其他师傅账号：13800138002-13800138010 / 123456</text>
  </view>
</view>