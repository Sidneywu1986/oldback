.balance-info {
  text-align: center;
  padding: 32rpx;
  background: #FEF3C7;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.balance-label {
  font-size: 28rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 12rpx;
}

.balance-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #D97706;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 12rpx;
  display: block;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.amount-symbol {
  font-size: 36rpx;
  color: #6B7280;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  height: 88rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
}

.quick-amounts {
  margin-bottom: 24rpx;
}

.quick-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  display: block;
}

.quick-btns {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  flex: 1;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #374151;
}

.quick-btn:active {
  background: #E5E7EB;
}

.payment-method {
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
}

.method-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.method-item.active {
  border-color: #2563EB;
}

.method-icon {
  font-size: 40rpx;
}

.method-info {
  flex: 1;
}

.method-name {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
  display: block;
}

.method-desc {
  font-size: 24rpx;
  color: #9CA3AF;
}

.method-check {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}

.tips {
  background: #EFF6FF;
  border-radius: 12rpx;
  padding: 20rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  background: #D1D5DB;
}